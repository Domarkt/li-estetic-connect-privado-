// Li Estetic Connect — modelo de datos
// Multi-sucursal con aislamiento por branchId. Cubre todas las fases del handoff.

generator client {
  provider      = "prisma-client-js"
  // native = dev local; linux-musl-openssl-3.0.x = contenedor node:20-alpine (Render)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: DATABASE_URL usa el pooler (6543); DIRECT_URL la conexión directa (5432) para migraciones.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN // Administradora (Dueña/Directora) — ve las 3 sucursales
  RECEPCIONISTA // Recepcionista — solo su sucursal, factura
  ESTETICISTA // Esteticista (Masajista) — solo su sucursal, parte clínica
}

enum FichaStatus {
  PENDIENTE // ficha no completada -> paciente "Nuevo"
  PASO1_OK // recepción completó el Paso 1, enviado a esteticista
  COMPLETA // esteticista terminó -> paciente pasa a "Recurrente"
}

enum PatientType {
  NUEVO
  RECURRENTE
}

enum AppointmentStatus {
  SIN_CONFIRMAR
  CONFIRMADA
  COMPLETADA
  CANCELADA
  REAGENDADA
}

enum CatalogKind {
  SERVICIO
  PAQUETE
  COMBO
  PRODUCTO
  INSUMO // insumo operativo (toallas, wiper, papel, sábanas, alcohol, gel...) — no se vende
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  AZUL
}

enum InvoiceStatus {
  PENDIENTE
  PAGADA
  ANULADA
}

enum ReceiptSize {
  CARTA
  TICKET_80
  TICKET_58
}

enum Channel {
  INSTAGRAM
  WHATSAPP
  MESSENGER
  TIKTOK
}

enum PipelineStage {
  NUEVO_MENSAJE
  EN_CONVERSACION
  COTIZADO
  CITA_AGENDADA
  VENDIDO
}

enum PointsTier {
  ORO
  PLATA
  BRONCE
}

enum PointsReason {
  MANUAL
  VENTA
  PUNTUALIDAD
  META
  REFERIDO
  RESENA
  DEDUCCION
  CANJE
}

enum ChargeItemStatus {
  PENDIENTE_FACTURAR // cargado por esteticista, esperando recepción
  FACTURADO
}

// ─────────────────────────────────────────────────────────────
// SUCURSALES
// ─────────────────────────────────────────────────────────────

model Branch {
  id            String   @id @default(cuid())
  code          String   @unique // e1, e2, e3
  name          String // Estética 1
  place         String // Plaza San Vicente, 1er nivel
  dotColor      String // color de marca de la sucursal
  address       String // dirección impresa en el recibo
  phone         String   @default("809-000-0000")
  email         String? // correo de la sucursal (contacto + reply-to de los correos a pacientes)
  // Metas (parametrizables por Admin — Fase 6)
  monthlyGoal   Int      @default(0)
  dailyGoal     Int      @default(0)
  perAsesorGoal Int      @default(0)
  createdAt     DateTime @default(now())

  users         User[]
  patients      Patient[]
  appointments  Appointment[]
  invoices      Invoice[]
  conversations Conversation[]
  leads         Lead[]
  chargeItems   ChargeItem[]
  goals         BranchGoal[]
  cashCloses    CashClose[]
  stockLevels   StockLevel[]
  stockMoves    StockMovement[]
  assets        Asset[]
}

// Cierre de caja diario (conteo ciego por recepción, cuadre por admin)
model CashClose {
  id               String    @id @default(cuid())
  branchId         String
  day              DateTime // fecha del cierre (00:00 local)
  status           String    @default("ENVIADO") // ENVIADO | CUADRADO
  // Conteo de recepción
  denominations    Json // { "2000": qty, "1000": qty, ... } efectivo
  cardVouchers     Json // [montos de vouchers de tarjeta]
  countedCash      Int       @default(0)
  countedCard      Int       @default(0)
  countedTransfer  Int       @default(0)
  countedAzul      Int       @default(0)
  // Snapshot de lo ESPERADO según facturas del día (no visible para recepción)
  expectedCash     Int       @default(0)
  expectedCard     Int       @default(0)
  expectedTransfer Int       @default(0)
  expectedAzul     Int       @default(0)
  notes            String?
  submittedById    String?
  reconciledById   String?
  reconciledAt     DateTime?
  // Resolución del descuadre por el administrador
  adminNote        String? // comentario: a qué se debe la diferencia
  resolution       String? // NONE | REAL_OK | FALTANTE_DESCONTAR | SOBRANTE_DEPOSITAR | AJUSTE_METODO
  deductUserId     String? // usuario al que se le descuenta el faltante real
  deductAmount     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, day])
}

// Expediente de descuentos al personal (faltantes reales de caja, etc.)
model StaffDeduction {
  id          String   @id @default(cuid())
  userId      String
  branchId    String
  amount      Int
  reason      String
  cashCloseId String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// USUARIOS (personal) — Admin / Recepción / Esteticista
// ─────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             Role
  branchId         String? // ADMIN puede ser null (todas las sucursales)
  active           Boolean  @default(true)
  // Permiso extra: gestionar el catálogo (servicios/productos) sin ser admin.
  canManageCatalog Boolean  @default(false)
  avatarColor      String   @default("#B31C86")
  createdAt        DateTime @default(now())

  branch Branch? @relation(fields: [branchId], references: [id])

  // Como esteticista asignada
  appointments     Appointment[]     @relation("TherapistAppointments")
  clinicalRecords  ClinicalRecord[]  @relation("TherapistRecords")
  invoicesIssued   Invoice[]         @relation("CashierInvoices")
  pointsLedger     PointsEntry[]
  redemptions      Redemption[]
  therapistProfile TherapistProfile?
  chargeItems      ChargeItem[]      @relation("ChargeItemCreatedBy")
  notifications    Notification[]
  deductions       StaffDeduction[]
  assetsAssigned   Asset[]           @relation("AssetAssignee")
  assetEvents      AssetEvent[]      @relation("AssetReporter")
}

// Alertas internas para el personal (aviso a la esteticista, ficha lista, etc.)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // NEW_APPOINTMENT | FICHA_FILLED | FICHA_SENT | GENERAL
  title     String
  body      String
  link      String? // ruta interna sugerida (p. ej. /app/agenda)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// Perfil de desempeño de la esteticista (puntos/comisiones — Fase 6)
model TherapistProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  points     Int      @default(0)
  monthSales Int      @default(0) // ventas del mes (base de comisión 8%)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// PACIENTES + FICHA CLÍNICA
// ─────────────────────────────────────────────────────────────

model Patient {
  id          String      @id @default(cuid())
  branchId    String
  name        String
  phone       String
  cedula      String?
  email       String?
  sex         String? // 'M' | 'F' — para redactar mensajes en género correcto
  age         Int?
  birthDate   DateTime?
  occupation  String?
  address     String?
  type        PatientType @default(NUEVO)
  avatarColor String      @default("#B31C86")
  createdAt   DateTime    @default(now())

  branch         Branch          @relation(fields: [branchId], references: [id])
  clinicalRecord ClinicalRecord?
  appointments   Appointment[]
  invoices       Invoice[]
  patientAccount PatientAccount?
  chargeItems    ChargeItem[]
  treatments     Treatment[]

  @@index([branchId])
  @@index([phone])
}

// Ficha clínica digital (una por paciente, 4 pasos divididos por rol)
model ClinicalRecord {
  id        String      @id @default(cuid())
  patientId String      @unique
  status    FichaStatus @default(PENDIENTE)
  fichaNo   Int         @default(autoincrement())

  // Paso 1 — Datos & motivo (Recepción)
  consultDate DateTime?
  motivos     String[] // Envejecimiento, Arrugas, Manchas, ...

  // Paso 2 — Antecedentes (Esteticista)
  antecedentes Json? // { alergias:bool, diabetes:bool, ... }
  ginecoObst   Json? // { embarazos, partos, abortos, lactancia }
  quirurgicos  Json? // { implantes, cirugia, observaciones }

  // Paso 3 — Medicamentos & piel (Esteticista)
  medicamentos Json? // { asa:bool, acenocumarol:bool, ... }
  fototipo     String? // I..VI (Fitzpatrick)
  tallaCm      Int?
  pesoLb       Int?
  alturaCm     Int? // estatura
  cinturaCm    Int? // medidas corporales (cm)
  abdomenCm    Int?
  piernaCm     Int?
  brazoCm      Int?

  // Paso 4 — Tratamiento (Esteticista)
  tratamiento     String?
  controlCitas    Json? // [{n, fecha, observaciones}] x10
  cancelPolicyAck Boolean @default(false)
  signatureData   String? // firma (base64/svg) — slot

  therapistId     String?
  sentToPatientAt DateTime? // recepción envió la ficha al paciente para autocompletarla
  patientFilledAt DateTime? // el paciente completó su parte clínica
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist User?   @relation("TherapistRecords", fields: [therapistId], references: [id])
}

// Tratamiento/paquete activo de un paciente (progreso de sesiones)
model Treatment {
  id            String    @id @default(cuid())
  patientId     String
  catalogItemId String?
  name          String
  totalSessions Int
  doneSessions  Int       @default(0)
  price         Int       @default(0) // valor total del paquete RD$
  balance       Int       @default(0) // saldo pendiente RD$ (pesos enteros)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem?         @relation(fields: [catalogItemId], references: [id])
  invoices    Invoice[]
  areas       TreatmentArea[]
  techniques  TreatmentTechnique[]

  @@index([patientId])
}

// Conteo por técnica dentro del combo del paciente (ej. 18 cavitaciones, 3 lipoláser).
// Se siembra al vender el combo y baja cada vez que la esteticista la aplica en una sesión.
model TreatmentTechnique {
  id          String @id @default(cuid())
  treatmentId String
  name        String
  total       Int
  done        Int    @default(0)

  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@unique([treatmentId, name])
  @@index([treatmentId])
}

// Catálogo de áreas del cuerpo (administrable): corporal (abdomen, espalda…) y láser
// (piernas, axilas…). La administración puede agregar más desde Configuración.
model BodyArea {
  id        String   @id @default(cuid())
  key       String   @unique // clave estable guardada en citas y tratamientos (ej. MUSLO)
  label     String // nombre visible (ej. Muslo)
  grupo     String // CORPORAL | LASER
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Área del cuerpo dentro de un combo. Un combo cubre 2 áreas y sus sesiones se
// reparten entre ellas (12 sesiones = 6 por área). Una 3ra área es adicional y
// se cobra aparte (RD$1,500): entra marcada como isExtra.
model TreatmentArea {
  id            String   @id @default(cuid())
  treatmentId   String
  area          String // ABDOMEN | ESPALDA | ABDOMEN_LATERAL
  totalSessions Int
  doneSessions  Int      @default(0)
  isExtra       Boolean  @default(false) // 3ra área: se cobra por separado
  createdAt     DateTime @default(now())

  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@unique([treatmentId, area])
  @@index([treatmentId])
}

// ─────────────────────────────────────────────────────────────
// CATÁLOGO — servicios / paquetes / combos / productos (Admin)
// ─────────────────────────────────────────────────────────────

model CatalogItem {
  id           String      @id @default(cuid())
  kind         CatalogKind
  code         String? // código/SKU del ítem (servicio, combo, paquete, insumo)
  showInPortal Boolean     @default(true) // si el paciente lo ve en el catálogo del portal
  name         String
  category     String?
  price        Int         @default(0) // RD$ (pesos enteros). 0 = sin precio: se define al cobrar.
  sessions     Int         @default(1)
  stock        Int? // (legacy) stock global; el stock real es por sucursal en StockLevel
  unit         String? // unidad de medida del producto/insumo: "unidad", "rollo", "litro", "caja"...
  tag          String? // "Ahorro RD$2,000", "Popular"
  areaGroup    String? // combos/paquetes: familia de áreas — CORPORAL | LASER (para el selector)
  defaultAreas String[]    @default([]) // áreas que trae el combo por defecto (se cargan al venderlo)
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())

  treatments  Treatment[]
  chargeItems ChargeItem[]
  stockLevels StockLevel[]
  stockMoves  StockMovement[]
  incluye     ComboService[]  @relation("ComboIncluye") // si es combo/paquete: técnicas que incluye
  incluidoEn  ComboService[]  @relation("ServicioEnCombo")
}

// Técnica/servicio incluido en un combo o paquete (vacumterapia, cavitación,
// radiofrecuencia, lipoláser...). La esteticista marca en cada sesión cuáles aplicó.
model ComboService {
  id        String @id @default(cuid())
  comboId   String
  serviceId String
  qty       Int    @default(1) // cantidad incluida de esta técnica (ej. 18 cavitaciones, 3 lipoláser)

  combo   CatalogItem @relation("ComboIncluye", fields: [comboId], references: [id], onDelete: Cascade)
  service CatalogItem @relation("ServicioEnCombo", fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([comboId, serviceId])
  @@index([comboId])
}

// Existencia de un producto/insumo en UNA sucursal (inventario aislado por sucursal).
model StockLevel {
  id            String   @id @default(cuid())
  branchId      String
  catalogItemId String
  qty           Int      @default(0) // existencia actual
  minQty        Int      @default(0) // umbral de alerta de stock bajo
  updatedAt     DateTime @updatedAt

  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([branchId, catalogItemId])
  @@index([branchId])
}

// Activos durables: EQUIPOS (láser, dermapen, computadora...) y SUMINISTROS que se
// entregan al personal (uniformes, herramientas, flota...). Cada uno con ID único
// e historial de mantenimiento/averías/incidentes.
model Asset {
  id           String   @id @default(cuid())
  code         String   @unique // etiqueta/ID del activo (EQ-0001 / SU-0001)
  kind         String // EQUIPO | SUMINISTRO
  name         String
  category     String? // láser, dermapen, computadora, uniforme, herramienta...
  branchId     String
  assignedToId String? // usuario al que se le entregó (suministros del personal)
  status       String   @default("OPERATIVO") // OPERATIVO | MANTENIMIENTO | AVERIADO | BAJA
  serial       String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  branch     Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedTo User?        @relation("AssetAssignee", fields: [assignedToId], references: [id])
  events     AssetEvent[]

  @@index([branchId, kind])
  @@index([assignedToId])
}

// Historial de un activo: entradas/salidas, mantenimientos, averías, incidentes.
model AssetEvent {
  id           String   @id @default(cuid())
  assetId      String
  type         String // ENTRADA | SALIDA | MANTENIMIENTO | AVERIA | INCIDENTE | NOTA | BAJA
  note         String?
  cost         Int? // costo del mantenimiento (RD$), opcional
  reportedById String?
  createdAt    DateTime @default(now())

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reportedBy User? @relation("AssetReporter", fields: [reportedById], references: [id])

  @@index([assetId, createdAt])
}

// Chat interno del equipo por sucursal (admin ↔ personal de la sucursal).
// El hilo es la sucursal (branchId). Datos del emisor/paciente denormalizados
// para no depender de relaciones (y sobrevivir a cambios de sucursal del paciente).
model TeamMessage {
  id             String   @id @default(cuid())
  branchId       String // hilo = sucursal
  senderId       String
  senderName     String
  senderRole     String // ADMIN | RECEPCIONISTA | ESTETICISTA
  targetRole     String   @default("ALL") // ALL | RECEPCIONISTA | ESTETICISTA — a quién va dirigido
  body           String   @default("") // puede ir vacío si el mensaje es solo un adjunto
  patientId      String? // paciente etiquetado (opcional)
  patientName    String?
  // Adjunto (foto/video/documento) guardado como data URL base64 en la propia DB.
  attachmentData String? // data:...;base64,... (límite ~10 MB)
  attachmentName String? // nombre original del archivo
  attachmentKind String? // image | video | file
  attachmentMime String? // tipo MIME original
  createdAt      DateTime @default(now())

  @@index([branchId, createdAt])
}

// Marca de "última lectura" por usuario y hilo (para el contador de no leídos).
model TeamThreadRead {
  id         String   @id @default(cuid())
  userId     String
  branchId   String
  lastReadAt DateTime @default(now())

  @@unique([userId, branchId])
}

// Movimiento de inventario (traza de entradas, ventas, consumo y ajustes) por sucursal.
model StockMovement {
  id            String   @id @default(cuid())
  branchId      String
  catalogItemId String
  delta         Int // + entrada, - salida
  reason        String // ENTRADA | VENTA | CONSUMO | AJUSTE
  note          String?
  createdById   String?
  createdAt     DateTime @default(now())

  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([branchId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// CITAS (agenda) + Google Calendar
// ─────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(cuid())
  branchId           String
  patientId          String
  therapistId        String?
  serviceName        String
  catalogItemId      String?
  treatmentId        String? // paquete/combo al que pertenece esta sesión (para descontarla al cerrar)
  areas              String[]          @default([]) // áreas trabajadas en esta cita (consume 1 sesión por área)
  techniques         String[]          @default([]) // checklist de técnicas aplicadas ese día (cavitación, radiofrecuencia...)
  startsAt           DateTime
  durationMin        Int               @default(60)
  status             AppointmentStatus @default(SIN_CONFIRMAR)
  patientType        PatientType       @default(RECURRENTE) // marcado al agendar
  sessionNo          Int? // sesión N del tratamiento
  notes              String?
  code               String?           @unique // código único de turno (lo valida la esteticista en cabina)
  codeUsedAt         DateTime? // cuándo se validó el código (turno abierto); evita reuso
  serviceStartedAt   DateTime? // inicia al abrir turno (contador, oculto para la esteticista)
  serviceEndedAt     DateTime? // "Proceso terminado"
  serviceDurationSec Int? // duración calculada del servicio
  rating             Int? // calificación del paciente (1-5)
  ratingComment      String? // comentario si la calificación es < 5
  googleEventId      String? // sync Google Calendar (Fase 3)
  reminderSentAt     DateTime?
  cancelReason       String? // motivo de cancelación (obligatorio al cancelar)
  cancelledBy        String? // STAFF | PATIENT
  cancelledAt        DateTime?
  createdAt          DateTime          @default(now())

  branch    Branch  @relation(fields: [branchId], references: [id])
  patient   Patient @relation(fields: [patientId], references: [id])
  therapist User?   @relation("TherapistAppointments", fields: [therapistId], references: [id])

  @@index([branchId, startsAt])
  @@index([patientId])
}

// Estado de integraciones de mensajería (WhatsApp / Meta / TikTok) — Fase Config
model Integration {
  id        String   @id @default(cuid())
  kind      String // 'whatsapp' | 'meta' | 'tiktok'
  scopeId   String   @default("global") // global o branchId
  status    String   @default("CONNECTED") // CONNECTED | DISCONNECTED
  mode      String   @default("demo") // demo | live
  meta      Json?
  createdAt DateTime @default(now())

  @@unique([kind, scopeId])
}

// Conexión OAuth a Google Calendar por usuario/sucursal (Fase 3)
model CalendarConnection {
  id           String    @id @default(cuid())
  ownerType    String // "user" | "branch"
  ownerId      String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  calendarId   String    @default("primary")
  createdAt    DateTime  @default(now())

  @@unique([ownerType, ownerId])
}

// ─────────────────────────────────────────────────────────────
// FACTURACIÓN (Recepción / Admin) — Fase 4
// ─────────────────────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique // F-2219
  branchId    String
  patientId   String?
  cashierId   String?
  therapistId String? // esteticista atribuida a la venta (para puntos/comisiones)
  treatmentId String? // si el cobro/abono aplica a un tratamiento
  concept     String
  subtotal    Int // RD$
  itbis       Int // 18%
  total       Int
  method      PaymentMethod // método dominante (para filtros/listado)
  payments    Json? // desglose de pago dividido: [{ method, amount }]
  paymentKind String        @default("TOTAL") // TOTAL | ABONO | SALDO
  status      InvoiceStatus @default(PAGADA)
  // DGII e-CF
  ncf         String? // secuencia NCF
  ecfTrackId  String? // TrackId DGII
  issuedAt    DateTime      @default(now())

  branch    Branch        @relation(fields: [branchId], references: [id])
  patient   Patient?      @relation(fields: [patientId], references: [id])
  cashier   User?         @relation("CashierInvoices", fields: [cashierId], references: [id])
  treatment Treatment?    @relation(fields: [treatmentId], references: [id])
  items     InvoiceItem[]

  @@index([branchId, issuedAt])
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String
  name      String
  qty       Int    @default(1)
  unitPrice Int
  total     Int

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// Secuencia de recibos / NCF por sucursal
model InvoiceSequence {
  id         String @id @default(cuid())
  branchId   String @unique
  lastNumber Int    @default(2218) // arranca cerca del prototipo
  ncfType    String @default("B02") // consumidor final
  lastNcf    Int    @default(0)
}

// Cargos que la esteticista envía a recepción para facturar (Fase 2/4)
model ChargeItem {
  id            String           @id @default(cuid())
  branchId      String
  patientId     String
  catalogItemId String?
  createdById   String?
  name          String
  price         Int
  status        ChargeItemStatus @default(PENDIENTE_FACTURAR)
  createdAt     DateTime         @default(now())

  branch      Branch       @relation(fields: [branchId], references: [id])
  patient     Patient      @relation(fields: [patientId], references: [id])
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id])
  createdBy   User?        @relation("ChargeItemCreatedBy", fields: [createdById], references: [id])

  @@index([branchId, status])
}

// ─────────────────────────────────────────────────────────────
// MENSAJERÍA OMNICANAL + PIPELINE — Fase 5
// ─────────────────────────────────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  branchId      String
  channel       Channel
  externalId    String? // id del hilo en la plataforma
  contactName   String
  contactHandle String?
  avatarColor   String   @default("#B31C86")
  unread        Int      @default(0)
  lastMessage   String?
  lastAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id])
  messages Message[]

  @@index([branchId, channel])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  fromMe         Boolean
  body           String
  externalId     String?
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Lead {
  id        String        @id @default(cuid())
  branchId  String
  patientId String? // vincula la tarjeta a un paciente para no duplicar (seguimiento automático)
  name      String
  summary   String?
  stage     PipelineStage @default(NUEVO_MENSAJE)
  channel   Channel?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, stage])
  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────
// PUNTOS "LÍDERES LI" + COMISIONES — Fase 6
// ─────────────────────────────────────────────────────────────

model PointsEntry {
  id        String       @id @default(cuid())
  userId    String
  points    Int // + o -
  reason    PointsReason @default(MANUAL)
  label     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Regla parametrizable de ganar/perder puntos (Admin)
model PointsRule {
  id        String  @id @default(cuid())
  label     String
  points    Int // + o -
  isEarn    Boolean // true=ganar, false=deducción
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

model Reward {
  id     String  @id @default(cuid())
  label  String
  cost   Int // puntos
  icon   String  @default("✦")
  active Boolean @default(true)

  redemptions Redemption[]
}

model Redemption {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  cost      Int
  status    String   @default("SOLICITADO") // SOLICITADO | APROBADO | ENTREGADO
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id])
}

// Meta mensual por sucursal (histórico parametrizable)
model BranchGoal {
  id        String @id @default(cuid())
  branchId  String
  period    String // "2026-07"
  monthly   Int
  daily     Int
  perAsesor Int

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, period])
}

// ─────────────────────────────────────────────────────────────
// PORTAL DEL PACIENTE (login externo separado) — Fase 7
// ─────────────────────────────────────────────────────────────

model PatientAccount {
  id           String   @id @default(cuid())
  patientId    String   @unique
  login        String   @unique // celular o cédula
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Código de un solo uso para entrar al portal (se guarda cifrado, nunca en claro).
  otpHash      String?
  otpExpiresAt DateTime?
  otpAttempts  Int       @default(0)
  otpSentAt    DateTime?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  purchaseRequests PurchaseRequest[]
}

// Solicitud de compra de paquete desde el portal (recepción gestiona)
model PurchaseRequest {
  id               String   @id @default(cuid())
  patientAccountId String
  catalogItemId    String?
  itemName         String
  status           String   @default("SOLICITADO") // SOLICITADO | GESTIONADO
  createdAt        DateTime @default(now())

  patientAccount PatientAccount @relation(fields: [patientAccountId], references: [id], onDelete: Cascade)
}

// Registro de auditoría: quién hizo qué y cuándo. Imprescindible con datos
// clínicos y dinero en efectivo (quién leyó una ficha, quién cobró o anuló,
// quién cambió un precio). Se guarda el nombre en el momento del hecho, para
// que el rastro sobreviva aunque después se desactive al usuario.
model AuditLog {
  id       String   @id @default(cuid())
  at       DateTime @default(now())
  userId   String?
  userName String?
  role     String?
  branchId String?
  action   String // FICHA_VIEW | INVOICE_CREATE | APPOINTMENT_CANCEL | PRICE_CHANGE ...
  entity   String // Patient | Invoice | Appointment | CatalogItem ...
  entityId String?
  summary  String? // texto legible para la pantalla de auditoría
  ip       String?

  @@index([at])
  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
}
