# API
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production-staff
JWT_PATIENT_SECRET=change-me-in-production-patient
JWT_EXPIRES=12h

# Contraseñas demo del seed
SEED_STAFF_PASSWORD=liestetic
SEED_PATIENT_PASSWORD=paciente

# Google Calendar (Fase 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/oauth/callback

# DGII e-CF (Fase 4)
DGII_ECF_ENV=test

# Meta / WhatsApp / TikTok (Fase 5)
META_APP_SECRET=
WHATSAPP_TOKEN=
TIKTOK_APP_SECRET=

# Correo (envío de acceso al portal para completar la ficha). Sin esto, modo demo
# (recepción comparte las credenciales manualmente).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Li Estetic Center <no-reply@liestetic.do>
PORTAL_URL=http://localhost:5173/portal/login
